{
  "name": "sprinter",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check:format": "oxfmt --check .",
    "check:lint": "oxlint --deny-warnings packages apple/Sprinter/scripts",
    "check:types": "tsc --noEmit",
    "check:test": "bun --bun vitest run --coverage",
    "check:goldens": "bun run apple/Sprinter/scripts/check-goldens.ts",
    "check": "bun run check:format && bun run check:lint && bun run check:types && bun run check:test && bun run check:goldens"
  },
  "devDependencies": {
    "@effect/platform-bun": "4.0.0-beta.97",
    "@effect/vitest": "4.0.0-beta.97",
    "@types/bun": "1.3.14",
    "@vitest/coverage-istanbul": "4.1.10",
    "effect": "4.0.0-beta.97",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "packageManager": "bun@1.4.0"
}
