{
  "name": "sprinter",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check:pins": "bun run scripts/check-pins.ts",
    "check:format": "oxfmt --check .",
    "check:lint": "oxlint",
    "check:types": "tsc --noEmit",
    "check:test": "bun test --coverage",
    "check": "bun run check:pins && bun run check:format && bun run check:lint && bun run check:types && bun run check:test"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2"
  },
  "packageManager": "bun@1.4.0"
}
